{
    "keyboard_name": "patra60",
    "url": "https://github.com/yuna495",
    "maintainer": "yuna495",
    "width": 17,
    "height": 5,
    "bootloader": "rp2040",
    "pages": {
        "features": {
            "bootmagic": false,
            "extrakey": true,
            "mousekey": true,
            "nkro": true,
            "oled": true,
            "encoder": true,
            "split_keyboard": true
        }
    },
    "matrix_pins": {
        "cols": ["GP0", "GP1", "GP2", "GP3", "GP4", "GP5", "GP6"],
        "rows": ["GP9", "GP10", "GP11", "GP12", "GP13"]
    },
    "split": {
        "enabled": true,
        "matrix_pins": {
            "right": {
                "cols": ["GP0", "GP1", "GP2", "GP3", "GP4", "GP5", "GP6"],
                "rows": ["GP9", "GP10", "GP11", "GP12", "GP13"]
            }
        }
    },
    "encoder": {
        "rotary": [
            { "pin_a": "GP7", "pin_b": "GP8" }
        ]
    }
}
